# =============================================================================
# Environment Variables Template
# Replace: {{SERVICE_NAME}}, {{PORT}}
# Copy to .env and fill in values: cp .env.sample .env
# =============================================================================

# ===================
# Domain & Deployment
# ===================
DOMAIN={{SERVICE_NAME}}.example.com
PORT={{PORT}}

# ===================
# Database
# ===================
POSTGRES_DB={{SERVICE_NAME}}
POSTGRES_USER={{SERVICE_NAME}}
POSTGRES_PASSWORD=change-me-in-production

# Connection string for application
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ===================
# Application
# ===================
NODE_ENV=production
# Add your application-specific variables here

# ===================
# Redis (if using)
# ===================
# REDIS_URL=redis://redis:6379

# ===================
# Auto-updates (Watchtower)
# ===================
WATCHTOWER_SCOPE={{SERVICE_NAME}}

# ===================
# Basic Auth (optional)
# Generate with: htpasswd -nb username password
# Or use: scripts/generate-htpasswd.sh username password
# ===================
# USERNAME=admin
# HASHED_PASSWORD='$$apr1$$...'
